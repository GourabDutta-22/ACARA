# ─────────────────────────────────────────────────────────────
#  ACARA Backend — Environment Variables
#  Copy this file to .env and fill in your keys.
# ─────────────────────────────────────────────────────────────

# Required: OpenAI (LLM + Embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Required: Tavily (Web search fallback)
TAVILY_API_KEY=your_tavily_api_key_here

# Required: MongoDB (Chat history persistence)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/agentic_rag

# Optional: Pinecone (Cloud vector store — falls back to local ChromaDB if not set)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=acara-index
